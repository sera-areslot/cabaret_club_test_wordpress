# Copy to .env and adjust as needed.  ( cp .env.example .env )

# Database
DB_NAME=lumiere
DB_USER=lumiere
DB_PASSWORD=lumiere
DB_ROOT_PASSWORD=rootpass

# WordPress
WP_PORT=8080
WP_URL=http://localhost:8080
WP_DEBUG=1

# Admin account created on first install
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com
